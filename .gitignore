# ============================================================
#  Racconotes — .gitignore (Unity + .NET / Rider)
# ============================================================

# ----- Unity -----
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Asset meta data — keep .meta only for files that are committed
# (Unity generates these; do not ignore globally, but ignore for ignored folders above)

# Autogenerated VS/Rider solution & project files for the Unity side
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln.DotSettings.user
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files for ignored content
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Crashlytics
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ----- .NET / Rider -----
[Bb]in/
[Dd]ebug/
[Rr]elease/
[Xx]64/
[Xx]86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
project.lock.json
project.fragment.lock.json
artifacts/
*.user
*.userosscache
*.sln.docstates
.vs/
TestResults/
[Tt]est[Rr]esult*/
*.nupkg
*.snupkg
# NB: do NOT ignore a "Packages/" folder here — Unity's Packages/manifest.json
# must be committed. Projects use PackageReference, so there is no NuGet packages/ dir.

# JetBrains Rider / IntelliJ
.idea/
*.DotSettings.user

# ----- OS / misc -----
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
